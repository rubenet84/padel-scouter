# Base de datos
DATABASE_URL=postgresql+psycopg2://padel:padel_dev@localhost:5432/padel_scouter

# Redis
REDIS_URL=redis://localhost:6379

# Seguridad JWT
SECRET_KEY=cambia_esto_por_una_clave_de_minimo_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Token de reset de contraseña — OWASP A07 (corta duración)
