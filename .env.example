# Google AI (Gemini)
GOOGLE_API_KEY=tu_clave_de_api_de_google_aqui

# App
APP_ENV=development
APP_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (Resend)
RESEND_API_KEY=tu_resend_api_key
# Email del remitente (debe estar verificado en Resend)
EMAILS_FROM=Padel Scouter <onboarding@resend.dev>
# En desarrollo, Resend solo permite enviar al email del dueño de la cuenta
RESEND_OWNER_EMAIL=tu_email@example.com